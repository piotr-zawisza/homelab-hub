<!DOCTYPE html>
<html lang="<%= lang %>">

<head>
  <%- include('../partials/head', { title: 'Fabula Ultima - Project Creator' }) %>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/html2canvas/1.4.1/html2canvas.min.js" defer
      nonce="<%= nonce %>"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/lz-string/1.5.0/lz-string.min.js" defer
      nonce="<%= nonce %>"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/qrious/4.0.2/qrious.min.js" defer nonce="<%= nonce %>"></script>
    <script src="https://cdn.jsdelivr.net/npm/jsqr@1.4.0/dist/jsQR.min.js" defer nonce="<%= nonce %>"></script>

    <link rel="stylesheet" href="/css/common/toast.css">
    <script src="/js/common/toast.js" nonce="<%= nonce %>"></script>

    <script type="module" src="/js/fu-projects/main.js" defer nonce="<%= nonce %>"></script>
    <link rel="stylesheet" href="/css/fu-projects/style.css">
</head>
<script id="app-context" type="application/json" nonce="<%= nonce %>">
    <%- JSON.stringify({ lang: lang, dict: t, config: appConfig, isLoggedIn: locals.isLoggedIn }) %>
</script>
<script src="/js/common/init.js" nonce="<%= nonce %>"></script>
<script src="/js/common/auth.js" nonce="<%= nonce %>"></script>

<body>
  <%- include('../partials/auth-modal') %>
    <div class="fu-layout">
      <div id="drag-overlay">
        <div class="drag-message">
          <span style="font-size: 48px">📂</span><br />
          <span data-i18n="drag_msg">Drop a file here to load</span>
        </div>
      </div>
      <div id="creator-panel" class="box">
        <div class="back-link-container">
          <a href="../" class="nav-link" id="btn-back">
            <span class="arrow">⮌</span> <span data-i18n="btn_back">Back</span>
          </a>
        </div>

        <div class="lang-switcher-panel">
          <button id="btn-lang-pl" class="btn-lang">PL</button>
          <button id="btn-lang-en" class="btn-lang">EN</button>
        </div>

        <h2 class="panel-title"
          style="display: flex; justify-content: space-between; align-items: center; clear: both; padding-top: 10px;">
          <span data-i18n="creator_title">Project Creator</span>
          <span id="ui-sync-status" style="
            font-size: 11px;
            color: #888;
            text-transform: none;
            letter-spacing: normal;
          "></span>
        </h2>

        <fieldset class="param-group">
          <legend data-i18n="lbl_params">Multiplier Parameters</legend>
          <div class="config-row">
            <div class="form-group">
              <label for="in-potential" data-i18n="lbl_potential">Potential</label>
              <select id="in-potential" class="form-control">
                <option value="100" data-i18n="opt_pot_low" data-i18n-title="desc_pot_low"></option>
                <option value="200" data-i18n="opt_pot_avg" data-i18n-title="desc_pot_avg"></option>
                <option value="400" data-i18n="opt_pot_high" data-i18n-title="desc_pot_high" selected></option>
                <option value="800" data-i18n="opt_pot_huge" data-i18n-title="desc_pot_huge"></option>
              </select>
            </div>
            <div class="live-calc" id="out-potential">400 z</div>
          </div>

          <div class="config-row">
            <div class="form-group">
              <label for="in-area" data-i18n="lbl_area">Area</label>
              <select id="in-area" class="form-control">
                <option value="1" data-i18n="opt_area_single" data-i18n-title="desc_area_single"></option>
                <option value="2" data-i18n="opt_area_small" data-i18n-title="desc_area_small" selected></option>
                <option value="3" data-i18n="opt_area_large" data-i18n-title="desc_area_large"></option>
                <option value="4" data-i18n="opt_area_huge" data-i18n-title="desc_area_huge"></option>
              </select>
            </div>
            <div class="live-calc" id="out-area">x2</div>
          </div>

          <div class="config-row">
            <div class="form-group">
              <label for="in-use" data-i18n="lbl_use">Usage</label>
              <select id="in-use" class="form-control">
                <option value="1" data-i18n="opt_use_single" data-i18n-title="desc_use_single" selected></option>
                <option value="5" data-i18n="opt_use_perm" data-i18n-title="desc_use_perm"></option>
              </select>
            </div>
            <div class="live-calc" id="out-use">x1</div>
          </div>
        </fieldset>

        <div class="config-row flaw-row">
          <div class="checkbox-group">
            <input type="checkbox" id="in-flaw" checked />
            <label for="in-flaw" data-i18n="lbl_flaw">Flaw</label>
          </div>
          <div class="live-calc flaw-val" id="out-flaw">x0.75</div>
        </div>

        <div class="total-summary">
          <div class="total-row">
            <span data-i18n="lbl_total_cost"></span>
            <span class="val" id="total-cost">600 z</span>
          </div>
          <div class="total-row clock-row">
            <div class="clock-label-group">
              <span data-i18n="lbl_total_progress"></span>
            </div>
            <div class="clock-value-group">
              <span class="val cyan" id="total-progress">T6 (6 sections)</span>
            </div>
          </div>
        </div>

        <fieldset class="param-group action-group">
          <legend data-i18n="lbl_export">Export</legend>
          <div class="download-buttons" style="display: flex; gap: 10px">
            <button id="btn-save" class="btn btn-primary" style="flex: 1" data-i18n="btn_download_png">PNG</button>
            <button id="btn-save-qr" class="btn btn-primary btn-qr" style="flex: 1;" data-i18n="btn_download_qr">
              PNG + QR
            </button>
          </div>
        </fieldset>

        <fieldset class="param-group action-group">
          <legend data-i18n="lbl_data">File Management</legend>
          <div class="json-buttons" style="display: flex; gap: 10px">
            <button id="btn-load" class="btn btn-secondary" style="flex: 1" data-i18n="btn_load">Load</button>
            <button id="btn-save-json" class="btn btn-secondary" style="flex: 1"
              data-i18n="btn_save_json">.JSON</button>
          </div>
        </fieldset>
        <input type="file" id="input-load" accept=".json, image/*" style="display: none" />
      </div>

      <div id="preview-area">
        <div id="card-scale-wrapper">
          <div id="project-card">
            <div class="fu-table-header">
              <div data-i18n="th_invention">Invention</div>
              <div data-i18n="th_potential">Potential</div>
              <div data-i18n="th_area">Area</div>
              <div data-i18n="th_use">Usage</div>
            </div>
            <div class="fu-row-inputs">
              <div class="fu-name-cell" id="card-name" contenteditable="true" spellcheck="false"></div>
              <div id="card-potential"></div>
              <div id="card-area"></div>
              <div id="card-use"></div>
            </div>
            <div class="fu-summary-bar">
              <div>
                <strong data-i18n="card_cost_text"></strong>
                <span id="card-cost">600</span>
                <span data-i18n="lbl_currency">zenits</span>
              </div>
              <div>
                <strong data-i18n="card_progress_text"></strong>
                <span id="card-progress">6</span>
              </div>
              <div>
                <strong data-i18n="card_flaw_text"></strong>
                <span id="card-flaw"></span>
              </div>

              <div id="card-qr-container"></div>
            </div>
            <div class="fu-description" id="card-desc" contenteditable="true" spellcheck="false"></div>
            <div class="fu-flaw-description" id="card-flaw-desc-block">
              <div class="fu-flaw-label" data-i18n="lbl_flaw_desc"></div>
              <div id="card-flaw-desc" contenteditable="true" spellcheck="false"></div>
            </div>
          </div>
        </div>
      </div>
      <div id="toast-container"></div>
    </div>
</body>

</html>
