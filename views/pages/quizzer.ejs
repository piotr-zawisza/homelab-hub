<!DOCTYPE html>
<html lang="<%= lang %>" id="html-lang">

<head>
  <%- include('../partials/head', { title: 'Quiz Reader' }) %>
    <link href="https://fonts.googleapis.com/css2?family=Signika+Negative:wght@300;400;600&display=swap"
      rel="stylesheet" nonce="<%= nonce %>">
    <link rel="stylesheet" href="/css/quizzer/style.css">
</head>
<script id="app-context" type="application/json" nonce="<%= nonce %>">
      <%- JSON.stringify({ lang: lang, dict: t, config: appConfig, isLoggedIn: locals.isLoggedIn }) %>
  </script>
<script src="/js/common/init.js" nonce="<%= nonce %>"></script>
<script src="/js/common/auth.js" nonce="<%= nonce %>"></script>

<body>
  <%- include('../partials/auth-modal') %>
    <div class="quizzer-layout">
      <div class="quiz-container">

        <div style="display: flex; gap: 20px; margin-bottom: 15px;">
          <a href="/" class="nav-link" id="lang-backToHub">
            <%= t.quizzer.backToHub %>
          </a>
          <a href="#" class="nav-link" id="btn-back-to-menu" style="display: none;">
            <%= t.quizzer.backToMenu || "← Menu" %>
          </a>
        </div>

        <div id="quiz-menu" class="box" style="text-align: center; margin-bottom: 20px;">
          <h2 class="panel-title" style="border: none;">
            <%= t.quizzer.chooseQuiz %>
          </h2>
          <div style="display: flex; gap: 10px; justify-content: center; flex-wrap: wrap; margin-top: 15px;">
            <% if (locals.quizSets && quizSets.length> 0) { %>
              <% quizSets.forEach(set=> { %>
                <button class="btn btn-secondary btn-select-quiz" data-file="<%= set %>">
                  <%= set %>
                </button>
                <% }) %>
                  <% } else { %>
                    <span style="color: var(--text-muted);">
                      <%= t.quizzer.noQuizSets %>
                    </span>
                    <% } %>
          </div>
        </div>

        <div id="quiz-box" class="box" style="display: none;">
          <div class="header-row">
            <div class="progress">
              <span id="lang-question">
                <%= t.quizzer.question %>
              </span>
              <span id="current-q">0</span> / <span id="total-q">0</span>
            </div>
            <div class="score-display">
              <span id="lang-score">
                <%= t.quizzer.score %>
              </span> <span id="score">0</span>
            </div>
          </div>

          <div class="progress-bar-container">
            <div id="quiz-progress" class="progress-bar-fill"></div>
          </div>

          <div id="question-content">
            <h2 id="question-text">
              <%= t.quizzer.loading %>
            </h2>
            <div id="answers-container"></div>
          </div>

          <div id="action-buttons" style="
            display: none;
            flex-direction: column;
            gap: 15px;
            margin-top: 25px;
          ">
            <div class="timer-bar-container">
              <div id="skip-timer-bar" class="timer-bar-fill"></div>
            </div>

            <div style="display: flex; gap: 15px">
              <button id="next-btn" class="btn btn-primary" style="display: none">
                <%= t.quizzer.next %>
              </button>
              <button id="stop-btn" class="btn btn-secondary">⏸<%= t.quizzer.pause %></button>
            </div>
          </div>
        </div>

        <div id="result-box" class="box" style="display: none; text-align: center">
          <h2 id="lang-quizEnd">
            <%= t.quizzer.quizEnd %>
          </h2>
          <p id="lang-yourScore">
            <%= t.quizzer.yourScore %>
          </p>
          <h1 id="final-score">0 / 0</h1>
          <p id="percentage-score" style="color: #a0a0b0"></p>

          <div style="display: flex; gap: 15px; justify-content: center; margin-top: 25px;">
            <button class="btn btn-primary" id="lang-tryAgain">
              <%= t.quizzer.tryAgain %>
            </button>
            <button class="btn btn-secondary" id="btn-choose-other">
              <%= t.quizzer.chooseOther || "Wybierz inny" %>
            </button>
          </div>
        </div>

      </div>
    </div>

    <script src="/js/quizzer/script.js" nonce="<%= nonce %>"></script>
</body>

</html>
