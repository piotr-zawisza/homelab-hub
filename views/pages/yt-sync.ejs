<!DOCTYPE html>
<html lang="<%= lang %>">

<head>
    <%- include('../partials/head', { title: t.yt_sync.title }) %>
        <link rel="stylesheet" href="/css/yt-sync/style.css">
        <link rel="stylesheet" href="/css/common/toast.css">
        <script src="/js/common/toast.js" nonce="<%= nonce %>"></script>

        <script id="app-context" type="application/json" nonce="<%= nonce %>">
        <%- JSON.stringify({ lang: lang, dict: t, isLoggedIn: locals.isLoggedIn }) %>
    </script>
        <script src="/js/common/init.js" nonce="<%= nonce %>"></script>
        <script src="/js/common/auth.js" nonce="<%= nonce %>"></script>
</head>

<body>
    <%- include('../partials/auth-modal') %>
        <div class="ytsync-layout">
            <div class="yt-sync-container">

                <div class="box">
                    <a href="/?lang=<%= lang %>" class="nav-link yt-nav-link">
                        <%= t.yt_sync.backToHub %>
                    </a>

                    <h1 class="mt-0">
                        <%= t.yt_sync.title %>
                    </h1>
                    <%= t.yt_sync.title %>
                        </h1>
                        <p class="yt-desc">
                            <%= t.yt_sync.desc %>
                        </p>
                        <%= t.yt_sync.desc %>
                            </p>

                            <% if (!locals.isLoggedIn) { %>
                                <div class="box yt-auth-req">
                                    <h2 class="panel-title">
                                        <%= t.yt_sync.authReq || "Authorization Required" %>
                                    </h2>
                                    <p>
                                        <%= t.yt_sync.authDesc || "Login in HUB" %>
                                    </p>
                                </div>
                                <% } else { %>

                                    <div class="form-section">
                                        <h2 class="panel-title">
                                            <%= t.yt_sync.dlTitle || "Download Once" %>
                                        </h2>
                                        <div class="yt-input-row">
                                            <input type="text" id="dl-url" class="form-control"
                                                placeholder="<%= t.yt_sync.dlPlaceholder || 'YouTube URL...' %>" />
                                            <button id="btn-download" class="btn btn-primary btn-nowrap">
                                                <%= t.yt_sync.dlBtn || 'Download' %>
                                            </button>
                                        </div>
                                    </div>

                                    <div class="form-section">
                                        <h2 class="panel-title">
                                            <%= t.yt_sync.syncTitle || "Add to Sync Schedule" %>
                                        </h2>
                                        <div class="yt-input-row">
                                            <input type="text" id="sync-url" class="form-control flex-2"
                                                placeholder="<%= t.yt_sync.syncPlaceholder || 'YouTube Playlist URL...' %>" />

                                            <input type="text" id="sync-target" class="form-control flex-1"
                                                placeholder="<%= t.yt_sync.targetPlaceholder || 'Identifier' %>" />

                                            <input type="number" id="sync-interval" class="form-control"
                                                style="width: 70px; text-align: center;" value="12" min="1"
                                                title="Interwał w godzinach" />

                                            <button id="btn-sync" class="btn btn-primary btn-nowrap">
                                                <%= t.yt_sync.syncBtn || 'Track' %>
                                            </button>
                                        </div>
                                    </div>

                                    <div class="form-section">
                                        <h2 class="panel-title">
                                            <%= t.yt_sync.tasksTitle || "Active Subscriptions" %>
                                        </h2>
                                        <div id="tasks-container">
                                            <p class="empty-state-text text-center" id="tasks-loading">
                                                <%= t.yt_sync.emptyState %>
                                            </p>
                                            <table class="yt-tasks-table d-none" id="tasks-table">
                                                <thead>
                                                    <tr class="yt-th-row">
                                                        <th class="yt-th-url">
                                                            <%= t.yt_sync.taskUrl || "URL" %>
                                                        </th>
                                                        <th class="yt-th-interval">
                                                            <%= t.yt_sync.taskInterval || "Interval" %>
                                                        </th>
                                                        <th class="yt-th-action">
                                                            <%= t.yt_sync.taskAction || "Action" %>
                                                        </th>
                                                    </tr>
                                                </thead>
                                                <tbody id="tasks-tbody">
                                                </tbody>
                                            </table>
                                            <p class="empty-state-text d-none text-center" id="tasks-empty">
                                                <%= t.yt_sync.tasksEmpty || "No active tasks." %>
                                            </p>
                                        </div>
                                    </div>

                                    <div class="form-section force-sync-section">
                                        <div>
                                            <h2 class="panel-title force-sync-title">
                                                <%= t.yt_sync.forceTitle %>
                                            </h2>
                                            <span class="force-sync-desc">
                                                <%= t.yt_sync.forceDesc %>
                                            </span>
                                        </div>
                                        <button id="btn-force" class="btn btn-secondary">
                                            <%= t.yt_sync.forceBtn %>
                                        </button>
                                    </div>
                </div>

                <div class="side-panel right-panel d-none" id="terminal-panel">
                    <div class="terminal-header">
                        <h2 class="panel-title terminal-title">
                            <%= t.yt_sync.logsTitle || "Live Console" %>
                        </h2>
                        <button id="btn-clear-logs" class="btn btn-secondary btn-small">
                            <%= t.yt_sync.clearBtn || "Clear" %>
                        </button>
                    </div>
                    <div class="terminal-viewer" id="log-output">
                        <span class="log-line system">
                            <%= t.yt_sync.consoleTxt || "Waiting" %>
                        </span>
                    </div>
                </div>

                <% } %>

            </div>
        </div>

        <script src="/js/yt-sync/script.js" nonce="<%= nonce %>"></script>
</body>

</html>
