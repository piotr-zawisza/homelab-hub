<button id="btn-global-auth-toggle" class="global-auth-btn <%= locals.isLoggedIn ? 'logged-in' : '' %>"
    aria-label="Toggle Auth">
    <% if (locals.isLoggedIn) { %>
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"
            stroke-linecap="round" stroke-linejoin="round">
            <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"></path>
            <circle cx="12" cy="7" r="4"></circle>
        </svg>
        <span class="auth-btn-text">
            <%= t.auth.btn_logout %>
        </span>
        <% } else { %>
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"
                stroke-linecap="round" stroke-linejoin="round">
                <rect x="3" y="11" width="18" height="11" rx="2" ry="2"></rect>
                <path d="M7 11V7a5 5 0 0 1 10 0v4"></path>
            </svg>
            <span class="auth-btn-text">
                <%= t.auth.btn_login %>
            </span>
            <% } %>
</button>

<div id="auth-modal-overlay" class="auth-modal-overlay">
    <div class="auth-modal-box">
        <button id="auth-modal-close" class="auth-modal-close">&times;</button>
        <h2 class="panel-title" style="margin-top: 0;">
            <%= t.auth.title %>
        </h2>

        <div class="auth-panel">
            <% if (!locals.isLoggedIn) { %>
                <input type="password" id="global-admin-pwd" class="form-control"
                    placeholder="<%= t.auth.pwd_placeholder %>" style="margin-bottom: 15px;">
                <button id="btn-global-login-submit" class="btn btn-primary" style="width: 100%;">
                    <%= t.auth.btn_login %>
                </button>
                <% } else { %>
                    <div
                        style="background: rgba(0, 230, 118, 0.1); border: 1px solid #00e676; color: #00e676; padding: 10px; border-radius: 6px; text-align: center; margin-bottom: 15px;">
                        <span style="font-weight: bold;">
                            <%= t.auth.status_logged_in %>
                        </span>
                    </div>
                    <button id="btn-global-logout-submit" class="btn btn-secondary" style="width: 100%;">
                        <%= t.auth.btn_logout %>
                    </button>
                    <% } %>
        </div>
    </div>
</div>
